# Garmin SDK (licensed - must be downloaded separately)
# Keep README.md files for setup instructions
ios/Frameworks/*.xcframework
ios/Frameworks/*.framework
android/libs/*.aar
android/libs/*.jar
android/repo/**/*.aar
!android/libs/README.md
!ios/Frameworks/README.md
vendor/garmin/
vendor/flux/

# Garmin RTS companion (cloned at build time)
.garmin/
# Also block any ad-hoc archive of the companion (e.g. a Finder-created
# `.garmin.zip`) that would otherwise ship the licensed overlay as a single
# blob if it ever hit `git add -A`.
.garmin.zip
.garmin.tar
.garmin.tar.gz
.garmin.tgz

# The companion overlay only replaces the licensed Kotlin native wrapper(s).
# All Dart code (adapters + models) lives in this repo as regular OSS files.
# We still must guard against the overlay leaking the Kotlin file as a symlink
# pointing into `.garmin/` (which uses absolute developer paths). The
# pre-commit hook + CI `make verify-clean` cover the runtime side; this rule
# keeps any other companion-only Kotlin files (e.g. `GarminHealthSdkWrapper.kt`,
# `GarminSdkWrapper.kt`) out of the index entirely.
android/src/main/kotlin/ai/synheart/wear/garmin/Garmin*Wrapper.kt

# `make link-garmin` saves the tracked OSS stub to `<path>.stub` before
# replacing it with a symlink, then `make clean-garmin` restores from the
# backup. The backup is purely a developer-machine artifact and must never be
# staged — `git add -A` would otherwise pick it up as a new file.
**/*.kt.stub

# Exceptions to above rules.
!**/ios/**/default.mode1v3
!**/ios/**/default.mode2v3
!**/ios/**/default.pbxuser
!**/ios/**/default.perspectivev3

