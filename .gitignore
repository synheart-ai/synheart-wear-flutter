*.lcov

# Garmin SDK (licensed - must be downloaded separately)
# Keep README.md files for setup instructions
ios/Frameworks/*.xcframework
ios/Frameworks/*.framework
android/libs/*.aar
android/libs/*.jar
android/repo/**/*.aar
!android/libs/README.md
!ios/Frameworks/README.md
vendor/garmin/
vendor/flux/

# Garmin RTS companion (cloned at build time)
.garmin/

# Files that the companion overlay symlinks in at build time. These MUST stay
# ignored so a careless `git add -A` after `make build-with-garmin` cannot
# leak licensed code (or worse — absolute-path symlinks) into the open-source
# tree. The two stubs that exist in this repo (`garmin_health.dart` and
# `GarminSDKBridge.kt`) are explicitly re-included below.
lib/src/adapters/garmin/garmin_*.dart
!lib/src/adapters/garmin/garmin.dart
!lib/src/adapters/garmin/garmin_health.dart
lib/src/models/garmin_*.dart
android/src/main/kotlin/ai/synheart/wear/garmin/Garmin*.kt
!android/src/main/kotlin/ai/synheart/wear/garmin/GarminSDKBridge.kt

# Exceptions to above rules.
!**/ios/**/default.mode1v3
!**/ios/**/default.mode2v3
!**/ios/**/default.pbxuser
!**/ios/**/default.perspectivev3

